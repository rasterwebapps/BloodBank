{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(ng *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kubectl *)",
      "Bash(flyway *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(java -version)",
      "Bash(node -v)",
      "Bash(bash .claude/hooks/*)",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)"
    ]
  },
  "hooks": {
    "PostToolCall": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "command": "bash .claude/hooks/validate-no-lombok.sh",
        "description": "Validate no Lombok annotations in generated code"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "command": "bash .claude/hooks/validate-code-patterns.sh",
        "description": "Validate BloodBank code conventions (@PreAuthorize, constructor injection, records, etc.)"
      }
    ],
    "PrePush": [
      {
        "command": "bash .claude/hooks/pre-push-checks.sh",
        "description": "Run all pre-push validation checks"
      }
    ]
  },
  "model": {
    "temperature": 0.2,
    "max_tokens": 16000
  },
  "project": {
    "name": "BloodBank",
    "type": "microservices",
    "language": "java",
    "framework": "spring-boot",
    "java_version": 21,
    "build_tool": "gradle-kotlin-dsl",
    "frontend": "angular-21",
    "database": "postgresql-17",
    "no_lombok": true
  }
}